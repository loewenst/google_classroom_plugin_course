# Google OAuth Client ID — same value as the frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Service account key JSON (paste entire JSON as one line, or set via Secret Manager)
# This account needs: Drive file permission management, Sheets read/write
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Restrict CORS to your GitHub Pages origin in production
# Example: https://username.github.io
ALLOWED_ORIGIN=https://username.github.io
